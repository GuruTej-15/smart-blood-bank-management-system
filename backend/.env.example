PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/smart_blood_bank
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=20
ADMIN_BOOTSTRAP_CODE=one_time_bootstrap_code_for_first_admin_only
ADMIN_INVITE_EXPIRES_HOURS=24
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
SECURITY_PEPPER=change_this_to_random_secret
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_NAME=Smart Blood Bank
NODE_ENV=development

# Eligibility rule: minimum days between donations
DONATION_ELIGIBILITY_DAYS=90

# Inventory unit considered "low stock" below this count (per blood group)
LOW_STOCK_THRESHOLD=10

# Units expiring within this many days are flagged in expiry alerts
EXPIRY_ALERT_DAYS=7
